# PostgreSQL connection string (required for TypeORM)
DATABASE_URL=postgres://user:password@localhost:5432/letscode_dev_friendly

# Redis (optional; defaults shown)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Bitbucket Cloud REST API / clone auth (optional until you call Bitbucket APIs)
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=

# Where cloned repositories are stored (relative paths resolve from process.cwd())
REPO_BASE_PATH=./repos